{
  "info": {
    "name": "NERDCP — API Collection",
    "description": "National Emergency Response & Dispatch Coordination Platform\nCPEN 421 · University of Ghana\n\nAll 5 microservice endpoints. Set the `token` variable after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "nerdcp-cpen421-2024"
  },
  "variable": [
    { "key": "auth_url",      "value": "http://localhost:4001", "type": "string" },
    { "key": "incident_url",  "value": "http://localhost:4002", "type": "string" },
    { "key": "dispatch_url",  "value": "http://localhost:4003", "type": "string" },
    { "key": "analytics_url", "value": "http://localhost:4004", "type": "string" },
    { "key": "responder_url", "value": "http://localhost:4005", "type": "string" },
    { "key": "token",         "value": "PASTE_JWT_HERE",        "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth Service (4001)",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/auth/register", "host": ["{{auth_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nerdcp.gh\",\n  \"password\": \"admin123\",\n  \"name\": \"System Admin\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login (Get JWT)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                "pm.test('Login successful', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/auth/login", "host": ["{{auth_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nerdcp.gh\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login — Police",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/auth/login", "host": ["{{auth_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"police@nerdcp.gh\",\n  \"password\": \"police123\"\n}"
            }
          }
        },
        {
          "name": "Login — Fire Service",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/auth/login", "host": ["{{auth_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fire@nerdcp.gh\",\n  \"password\": \"fire123\"\n}"
            }
          }
        },
        {
          "name": "Login — Hospital",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/auth/login", "host": ["{{auth_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hospital@nerdcp.gh\",\n  \"password\": \"hospital123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Incident Service (4002)",
      "item": [
        {
          "name": "Create Incident",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{incident_url}}/incidents", "host": ["{{incident_url}}"], "path": ["incidents"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"fire\",\n  \"severity\": \"high\",\n  \"description\": \"Building fire on Ring Road Central\",\n  \"location\": {\n    \"lat\": 5.6037,\n    \"lng\": -0.1870\n  },\n  \"reporterName\": \"Officer Kofi\",\n  \"reporterPhone\": \"+233201234567\"\n}"
            }
          }
        },
        {
          "name": "Create Medical Incident",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{incident_url}}/incidents", "host": ["{{incident_url}}"], "path": ["incidents"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"medical\",\n  \"severity\": \"critical\",\n  \"description\": \"Cardiac arrest at Accra Mall\",\n  \"location\": {\n    \"lat\": 5.6342,\n    \"lng\": -0.1770\n  }\n}"
            }
          }
        },
        {
          "name": "Get All Incidents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{incident_url}}/incidents", "host": ["{{incident_url}}"], "path": ["incidents"] }
          }
        },
        {
          "name": "Get Incident by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{incident_url}}/incidents/:id", "host": ["{{incident_url}}"], "path": ["incidents", ":id"], "variable": [{ "key": "id", "value": "INCIDENT_ID_HERE" }] }
          }
        },
        {
          "name": "Update Incident Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{incident_url}}/incidents/:id/status", "host": ["{{incident_url}}"], "path": ["incidents", ":id", "status"], "variable": [{ "key": "id", "value": "INCIDENT_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            }
          }
        },
        {
          "name": "Dispatch Incident",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{incident_url}}/incidents/:id/dispatch", "host": ["{{incident_url}}"], "path": ["incidents", ":id", "dispatch"], "variable": [{ "key": "id", "value": "INCIDENT_ID_HERE" }] }
          }
        }
      ]
    },
    {
      "name": "3. Dispatch Service (4003)",
      "item": [
        {
          "name": "Update Vehicle Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{dispatch_url}}/dispatch/location", "host": ["{{dispatch_url}}"], "path": ["dispatch", "location"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"AMB-001\",\n  \"lat\": 5.6037,\n  \"lng\": -0.1870,\n  \"speed\": 65,\n  \"heading\": 180,\n  \"type\": \"ambulance\"\n}"
            }
          }
        },
        {
          "name": "Get Vehicle Location",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{dispatch_url}}/dispatch/location/:vehicleId", "host": ["{{dispatch_url}}"], "path": ["dispatch", "location", ":vehicleId"], "variable": [{ "key": "vehicleId", "value": "AMB-001" }] }
          }
        },
        {
          "name": "Get Active Dispatches",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{dispatch_url}}/dispatch/active", "host": ["{{dispatch_url}}"], "path": ["dispatch", "active"] }
          }
        },
        {
          "name": "[WS] Connect to Live Tracking",
          "request": {
            "method": "GET",
            "url": { "raw": "ws://localhost:4003/ws/track?incidentId=INCIDENT_ID_HERE" },
            "description": "Connect via WebSocket:\nURL: ws://localhost:4003/ws/track?incidentId=<ID>\n\nExpected message format:\n{\n  \"vehicleId\": \"AMB-001\",\n  \"lat\": 5.6037,\n  \"lng\": -0.1870,\n  \"speed\": 65,\n  \"type\": \"ambulance\",\n  \"timestamp\": \"2024-01-15T10:30:00Z\"\n}"
          }
        }
      ]
    },
    {
      "name": "4. Analytics Service (4004)",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{analytics_url}}/analytics/summary", "host": ["{{analytics_url}}"], "path": ["analytics", "summary"] }
          }
        },
        {
          "name": "Get Incidents by Type",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{analytics_url}}/analytics/incidents-by-type", "host": ["{{analytics_url}}"], "path": ["analytics", "incidents-by-type"] }
          }
        },
        {
          "name": "Get Response Times",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{analytics_url}}/analytics/response-times", "host": ["{{analytics_url}}"], "path": ["analytics", "response-times"] }
          }
        },
        {
          "name": "Get Resource Utilization",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{analytics_url}}/analytics/resource-utilization", "host": ["{{analytics_url}}"], "path": ["analytics", "resource-utilization"] }
          }
        }
      ]
    },
    {
      "name": "5. Responder Service (4005)",
      "item": [
        {
          "name": "Get All Responders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{responder_url}}/responders", "host": ["{{responder_url}}"], "path": ["responders"] }
          }
        },
        {
          "name": "Get Nearest Responders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{responder_url}}/responders/nearest?lat=5.6037&lng=-0.1870&type=fire",
              "host": ["{{responder_url}}"],
              "path": ["responders", "nearest"],
              "query": [
                { "key": "lat", "value": "5.6037" },
                { "key": "lng", "value": "-0.1870" },
                { "key": "type", "value": "fire" }
              ]
            }
          }
        },
        {
          "name": "Get Responder by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{responder_url}}/responders/:id", "host": ["{{responder_url}}"], "path": ["responders", ":id"], "variable": [{ "key": "id", "value": "RESPONDER_ID_HERE" }] }
          }
        }
      ]
    }
  ]
}
