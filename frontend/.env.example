# Frontend Environment Variables
# Copy this file to .env and fill in your values

VITE_AUTH_URL=https://auth-service-v8i7.onrender.com
VITE_INCIDENT_URL=https://incident-service-vebr.onrender.com
VITE_DISPATCH_URL=https://dispatch-service-8hws.onrender.com
VITE_ANALYTICS_URL=https://analytics-service-dlw1.onrender.com
VITE_RESPONDER_URL=https://responder-service.onrender.com

# WebSocket base URL (no http/https prefix)
VITE_WS_DISPATCH_URL= wss://dispatch-service-8hws.onrender.com

# Google Maps API Key (optional - app falls back to OpenStreetMap/Leaflet)
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
